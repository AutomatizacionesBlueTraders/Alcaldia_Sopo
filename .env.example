# PostgreSQL
POSTGRES_USER=sopo_admin
POSTGRES_PASSWORD=sopo_secret_2026
POSTGRES_DB=transporte_sopo

# Backend
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://sopo_admin:sopo_secret_2026@postgres:5432/transporte_sopo
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_REFRESH_SECRET=cambiar-este-refresh-secreto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL pública del frontend (usada en los enlaces de los correos)
APP_URL=http://localhost:5173

# CORS (CSV). Vacío = abierto (*). En producción, listar los orígenes permitidos.
# Ej: CORS_ORIGINS=https://mi-app.vercel.app,https://transporte.sopo.gov.co
CORS_ORIGINS=

# Resend — envío de correos transaccionales (bienvenida, reset de contraseña)
# https://resend.com/api-keys   —   dominio debe estar verificado en Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@transporte.sopo.gov.co
RESEND_FROM_NAME=Alcaldía de Sopó — Transporte
PASSWORD_RESET_TTL_MIN=60

# Rate limiting (set a "true" para desactivar — útil sólo en pruebas locales)
RATE_LIMIT_DISABLED=false

# Twilio (para descargar audios de WhatsApp en /api/whatsapp/mensaje)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# n8n API key (validada por el middleware requireApiKey)
N8N_API_KEY=

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambiar-en-produccion
N8N_HOST=n8n
N8N_PORT=5678
WEBHOOK_URL=https://tu-dominio.com/n8n/
