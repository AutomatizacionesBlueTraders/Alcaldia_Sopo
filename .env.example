# PostgreSQL
POSTGRES_USER=sopo_admin
POSTGRES_PASSWORD=sopo_secret_2026
POSTGRES_DB=transporte_sopo

# Backend
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://sopo_admin:sopo_secret_2026@postgres:5432/transporte_sopo
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_REFRESH_SECRET=cambiar-este-refresh-secreto
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Twilio (para descargar audios de WhatsApp en /api/whatsapp/mensaje)
