</table>

<!-- ============================================ -->
<h2><span class="section-number">7.</span> API HEALTH CHECK</h2>
<!-- ============================================ -->

<table>
<tr><th>#</th><th>Caso de Prueba</th><th>Pasos</th><th>Resultado Esperado</th><th class="pass">Pasa</th></tr>
<tr><td>7.1</td><td>Health endpoint</td><td>GET http://localhost:3000/api/health</td><td>Responde 200 OK</td><td class="center">&#9744;</td></tr>
<tr><td>7.2</td><td>API responde</td><td>GET http://localhost:3000/api/catalogos/tipos-servicio (con auth)</td><td>Retorna lista de tipos de servicio</td><td class="center">&#9744;</td></tr>
</table>

