<tr><td>Portal Conductor</td><td class="center">14</td><td>Iniciar/finalizar servicio, combustible, novedades</td></tr>
<tr><td>Flujos E2E</td><td class="center">16</td><td>Ciclo completo, cancelacion, rechazo, transferencia</td></tr>
<tr><td>UI / Navegacion</td><td class="center">6</td><td>Menus por rol, badges, accesibilidad</td></tr>
