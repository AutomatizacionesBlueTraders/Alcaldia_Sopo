                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "conductor"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "strict", "version": 3 },
                "conditions": [{ "leftValue": "={{ $json.tipo }}", "rightValue": "dependencia", "operator": { "type": "string", "operation": "equals" }, "id": "r2" }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "dependencia"
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
