      "id": "node-002",
      "name": "EXTRAER DATOS",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [420, 400]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.telefono_raw || '';\n// Normaliza: quita 'whatsapp:+57' o 'whatsapp:+' o 'whatsapp:'\nconst telefono = raw\n  .replace(/^whatsapp:\\+57/, '')\n  .replace(/^whatsapp:\\+/, '')\n  .replace(/^whatsapp:/, '')\n  .replace(/\\D/g, '');\nreturn {\n  telefono,\n  telefono_raw: $input.first().json.telefono_raw,\n  numero_from: $input.first().json.numero_from,\n  mensaje: $input.first().json.mensaje,\n  media_url: $input.first().json.media_url\n};"
      },
      "id": "node-003",
      "name": "NORMALIZAR TELEFONO",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [640, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://backend:3000/api/whatsapp/contexto?telefono={{ encodeURIComponent($json.telefono) }}",
        "options": {}
      },
      "id": "node-004",
