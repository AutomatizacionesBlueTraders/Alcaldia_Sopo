    },
    {
      "parameters": {
        "jsCode": "const lista = $input.first().json;\nif (!Array.isArray(lista) || lista.length === 0) {\n  return { mensaje: '📋 No tienes solicitudes activas.\\n\\nEscribe *1* para crear una nueva solicitud.' };\n}\nconst items = lista.map(s => {\n  const fecha = s.fecha_servicio?.toString().substring(0, 10);\n  return `• *#${s.id}* — ${fecha} ${s.hora_inicio?.substring(0,5) || ''} | ${s.origen} → ${s.destino} | Estado: *${s.estado}*`;\n}).join('\\n');\nreturn { mensaje: `📋 *Tus solicitudes activas:*\\n\\n${items}\\n\\nEscribe *menú* para ver más opciones.` };"
      },
      "id": "node-041",
      "name": "FORMATEAR SOLICITUDES",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1960, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{ $credentials.user }}/Messages.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "body": {
          "values": [
            { "name": "From", "value": "={{ $('NORMALIZAR TELEFONO').item.json.numero_from }}" },
            { "name": "To",   "value": "={{ $('NORMALIZAR TELEFONO').item.json.telefono_raw }}" },
            { "name": "Body", "value": "={{ $json.mensaje }}" }
          ]
        },
        "options": {}
      },
      "id": "node-042",
      "name": "ENVIAR CONSULTA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
