            { "name": "hora_inicio",       "value": "={{ $fromAI('hora_inicio', 'Hora en formato HH:MM') }}" },
            { "name": "origen",            "value": "={{ $fromAI('origen', 'Lugar de origen del servicio') }}" },
            { "name": "destino",           "value": "={{ $fromAI('destino', 'Lugar de destino del servicio') }}" },
            { "name": "pasajeros",         "value": "={{ $fromAI('pasajeros', 'Número de pasajeros') }}" },
            { "name": "dependencia_id",    "value": "={{ $fromAI('dependencia_id', 'ID numérico de la dependencia') }}" },
